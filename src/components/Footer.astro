---
const currentYear = new Date().getFullYear();

const productLinks = [
  { href: '/features/', label: 'Features' },
  { href: '/integrations/', label: 'Integrations' },
  { href: '/pricing/', label: 'Pricing' },
  { href: '/security/', label: 'Security' },
  { href: '/roadmap/', label: 'Roadmap' },
];

const compareLinks = [
  { href: '/compare/neubird/', label: 'vs NeuBird' },
  { href: '/compare/resolve/', label: 'vs Resolve AI' },
  { href: '/compare/ciroos/', label: 'vs Ciroos' },
  { href: '/compare/opensre/', label: 'vs OpenSRE' },
];

const resourceLinks = [
  { href: '/docs/', label: 'Documentation' },
  { href: '/blog/', label: 'Engineering blog' },
  { href: '/playground/', label: 'Playground' },
  { href: '/onepager/', label: 'One-pager (PDF)' },
  { href: '/about/', label: 'About' },
];

// Social icons render ONLY when a real destination exists.
// Discord: commented out until the server exists (task P5.7).
// X / LinkedIn: commented out until the company profiles exist — bare
// x.com / linkedin.com homepage links are worse than no link.
const socialLinks = [
  {
    label: 'GitHub',
    href: 'https://github.com/Srenix/agentic-sre',
    size: 20,
    path: 'M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.36-3.88-1.36-.53-1.34-1.29-1.7-1.29-1.7-1.06-.72.08-.7.08-.7 1.17.08 1.79 1.2 1.79 1.2 1.04 1.78 2.73 1.27 3.4.97.11-.76.41-1.27.74-1.56-2.56-.29-5.25-1.28-5.25-5.69 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.47.11-3.06 0 0 .98-.31 3.2 1.18a11.1 11.1 0 015.83 0c2.22-1.49 3.2-1.18 3.2-1.18.62 1.59.23 2.77.11 3.06.74.81 1.19 1.84 1.19 3.1 0 4.42-2.69 5.39-5.26 5.68.42.36.79 1.07.79 2.17v3.22c0 .31.21.67.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z',
  },
  // P5.7: re-enable once the Discord server is created — use the real invite URL.
  // {
  //   label: 'Discord',
  //   href: 'https://discord.gg/<real-invite>',
  //   size: 20,
  //   path: 'M20.317 4.37a19.79 19.79 0 00-4.885-1.515.07.07 0 00-.073.035c-.21.375-.444.864-.608 1.249a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.073-.035A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028 14.09 14.09 0 001.226-1.994.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.245.196.372.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.893.077.077 0 00-.041.106c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.84 19.84 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.548-13.66a.061.061 0 00-.031-.03z',
  // },
  // Re-enable with the real X profile URL once it exists.
  // {
  //   label: 'X / Twitter',
  //   href: 'https://x.com/<real-handle>',
  //   size: 18,
  //   path: 'M18.244 2H21.5l-7.5 8.575L23 22h-6.94l-5.43-7.107L4.36 22H1.1l8.05-9.2L1 2h7.13l4.91 6.49zM17.1 20h1.83L7.04 4H5.08z',
  // },
  // Re-enable with the real LinkedIn company page URL once it exists.
  // {
  //   label: 'LinkedIn',
  //   href: 'https://www.linkedin.com/company/<real-company>',
  //   size: 20,
  //   path: 'M19 0H5C2.24 0 0 2.24 0 5v14c0 2.76 2.24 5 5 5h14c2.76 0 5-2.24 5-5V5c0-2.76-2.24-5-5-5zM8 19H5V8h3v11zM6.5 6.73c-.97 0-1.75-.79-1.75-1.76S5.53 3.2 6.5 3.2s1.75.79 1.75 1.77S7.47 6.73 6.5 6.73zM20 19h-3v-5.6c0-3.37-4-3.11-4 0V19h-3V8h3v1.77c1.4-2.59 7-2.78 7 2.48V19z',
  // },
].filter((s) => s.href && !s.href.includes('<real-'));
---

<footer class="border-t border-zinc-200/70 bg-zinc-50/50 dark:border-zinc-800/70 dark:bg-zinc-950">
  <div class="mx-auto max-w-7xl px-6 py-14">
    <div class="grid gap-10 md:grid-cols-5">
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 font-semibold tracking-tight">
          <span class="grid h-8 w-8 place-items-center rounded-md bg-accent-600 text-white shadow-sm">
            <span class="text-xs font-bold">S</span>
          </span>
          <span class="text-zinc-900 dark:text-zinc-100">Agentic SRE</span>
        </div>
        <p class="mt-3 max-w-sm text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
          Detect, fix, and re-verify drift across Kubernetes, AWS, GCP, Azure, and
          the edge &mdash; without sending a byte of telemetry to a vendor SaaS.
        </p>
        <div class="mt-5 flex items-center gap-3 text-zinc-500 dark:text-zinc-400">
          {socialLinks.map((s) => (
            <a
              href={s.href}
              aria-label={s.label}
              class="rounded-md p-1.5 hover:bg-zinc-200/60 hover:text-zinc-900 dark:hover:bg-zinc-800 dark:hover:text-zinc-100"
            >
              <svg width={s.size} height={s.size} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d={s.path} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Product</h4>
        <ul class="mt-4 space-y-2 text-sm">
          {productLinks.map((l) => (
            <li>
              <a href={l.href} class="text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Compare</h4>
        <ul class="mt-4 space-y-2 text-sm">
          {compareLinks.map((l) => (
            <li>
              <a href={l.href} class="text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Resources</h4>
        <ul class="mt-4 space-y-2 text-sm">
          {resourceLinks.map((l) => (
            <li>
              <a href={l.href} class="text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-3 border-t border-zinc-200/70 pt-6 text-xs text-zinc-500 sm:flex-row sm:items-center dark:border-zinc-800/70 dark:text-zinc-500">
      <p>&copy; {currentYear} Srenix. Apache-2.0 OSS core.</p>
      <p>
        <a href="/legal/privacy/" class="hover:text-zinc-700 dark:hover:text-zinc-300">Privacy</a>
        <span class="px-2">&middot;</span>
        <a href="/legal/terms/" class="hover:text-zinc-700 dark:hover:text-zinc-300">Terms</a>
        <span class="px-2">&middot;</span>
        <a href="/security/" class="hover:text-zinc-700 dark:hover:text-zinc-300">Security</a>
      </p>
    </div>
  </div>
</footer>
