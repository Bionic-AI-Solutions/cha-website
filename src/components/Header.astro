---
const { pathname } = Astro.url;
const isActive = (href: string) =>
  pathname === href || (href !== '/' && pathname.startsWith(href));

const navLinks = [
  { href: '/features/', label: 'Features' },
  { href: '/integrations/', label: 'Integrations' },
  { href: '/compare/', label: 'Compare' },
  { href: '/pricing/', label: 'Pricing' },
  { href: '/security/', label: 'Security' },
  { href: '/docs/', label: 'Docs' },
];
---

<header class="sticky top-0 z-40 border-b border-zinc-200/70 bg-white/85 backdrop-blur dark:border-zinc-800/70 dark:bg-zinc-950/85">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6">
    <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
      <span class="grid h-8 w-8 place-items-center rounded-md bg-accent-600 text-white shadow-sm">
        <span class="text-xs font-bold">S</span>
      </span>
      <span class="text-zinc-900 dark:text-zinc-100">Srenix</span>
      <span class="hidden text-sm font-normal text-zinc-500 sm:inline dark:text-zinc-400">
        / Agentic SRE
      </span>
    </a>
    <nav class="hidden items-center gap-1 md:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'rounded-md px-3 py-1.5 text-sm font-medium transition-colors',
            isActive(link.href)
              ? 'text-accent-700 dark:text-accent-300'
              : 'text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100',
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-2">
      <a
        href="https://github.com/srenix-ai/agentic-sre"
        class="hidden text-sm font-medium text-zinc-600 hover:text-zinc-900 sm:inline dark:text-zinc-400 dark:hover:text-zinc-100"
      >
        GitHub
      </a>
      <!-- P6.8: once the hosted playground ships, point this back at /playground/ -->
      <a
        href="/docs/quick-start/"
        class="rounded-md bg-zinc-900 px-3.5 py-1.5 text-sm font-medium text-white shadow-sm transition hover:bg-zinc-800 dark:bg-white dark:text-zinc-900 dark:hover:bg-zinc-100"
      >
        Try it now
      </a>
      <!-- Mobile nav: no-JS details/summary disclosure; desktop nav above is unchanged -->
      <details class="group relative md:hidden">
        <summary
          class="grid h-9 w-9 cursor-pointer list-none place-items-center rounded-md text-zinc-600 hover:bg-zinc-200/60 hover:text-zinc-900 [&::-webkit-details-marker]:hidden dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-100"
          aria-label="Open navigation menu"
        >
          <svg class="block group-open:hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M4 7h16M4 12h16M4 17h16" />
          </svg>
          <svg class="hidden group-open:block" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M6 6l12 12M18 6L6 18" />
          </svg>
        </summary>
        <nav
          class="absolute right-0 top-12 z-50 w-60 rounded-lg border border-zinc-200/80 bg-white p-2 shadow-lg dark:border-zinc-800/80 dark:bg-zinc-950"
          aria-label="Mobile"
        >
          {navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                'block rounded-md px-3 py-2 text-sm font-medium transition-colors',
                isActive(link.href)
                  ? 'bg-accent-50 text-accent-700 dark:bg-accent-950/60 dark:text-accent-300'
                  : 'text-zinc-600 hover:bg-zinc-100 hover:text-zinc-900 dark:text-zinc-400 dark:hover:bg-zinc-900 dark:hover:text-zinc-100',
              ]}
            >
              {link.label}
            </a>
          ))}
          <a
            href="https://github.com/srenix-ai/agentic-sre"
            class="mt-1 block rounded-md border-t border-zinc-200/70 px-3 py-2 pt-3 text-sm font-medium text-zinc-600 hover:text-zinc-900 dark:border-zinc-800/70 dark:text-zinc-400 dark:hover:text-zinc-100"
          >
            GitHub
          </a>
        </nav>
      </details>
    </div>
  </div>
</header>
