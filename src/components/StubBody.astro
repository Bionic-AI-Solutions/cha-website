---
interface Props {
  claim?: string;
  backHref?: string;
  backLabel?: string;
}
const {
  claim,
  backHref = '/',
  backLabel = '← Back to home',
} = Astro.props;
---

<section class="mx-auto max-w-3xl px-6 py-20">
  <div class="rounded-2xl border border-zinc-200/80 bg-white p-10 shadow-sm dark:border-zinc-800/80 dark:bg-zinc-900/60">
    <div class="inline-flex items-center gap-2 rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-xs font-medium text-amber-800 dark:border-amber-900/50 dark:bg-amber-950/40 dark:text-amber-300">
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-amber-500"></span>
      Deep dive in progress
    </div>
    {claim && (
      <p class="mt-6 text-lg leading-relaxed text-zinc-700 dark:text-zinc-300">
        {claim}
      </p>
    )}
    <div class="mt-8 flex items-center gap-4 text-sm">
      <a
        href={backHref}
        class="font-medium text-accent-600 hover:text-accent-700 dark:text-accent-400 dark:hover:text-accent-300"
      >
        {backLabel}
      </a>
      <a
        href="https://github.com/srenix-ai/agentic-sre"
        class="text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100"
      >
        Read the code on GitHub →
      </a>
    </div>
  </div>

  <slot />
</section>
