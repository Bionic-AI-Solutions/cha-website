---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CompareTable from '../../components/CompareTable.astro';

const rows = [
  {
    dimension: 'Where it runs',
    cha: 'In your cluster — operator + CronJob + Deployment',
    competitor: 'Ciroos SaaS, "zero-copy" queries to customer observability',
  },
  {
    dimension: 'Safety brake on autonomy',
    cha: 'Named whitelisted fixers + dry-run + signed-JWT approval URLs',
    competitor: '"Automate / Augment / Autopilot" slider; no documented brake',
  },
  {
    dimension: 'Open source',
    cha: 'Apache-2.0 — full OSS feature set',
    competitor: 'Proprietary, private GitHub Enterprise',
  },
  {
    dimension: 'Pricing transparency',
    cha: 'Published list prices for OSS / Team / Enterprise',
    competitor: 'Contact sales only',
  },
  {
    dimension: 'Named customer logos',
    cha: 'None public yet (honest; neither does Ciroos at 12mo)',
    competitor: 'None — only "design partner" / "energy customer" references',
  },
];
---

<BaseLayout
  title="CHA vs. Ciroos"
  description="Ciroos has a strong multi-agent + KG architecture but is closed-source SaaS-only with no named customer logos at 12 months in. Our safety envelope is in code you can read."
>
  <PageHero
    eyebrow="Compare &middot; Ciroos"
    title="CHA vs. Ciroos"
    subtitle="Ciroos has a strong multi-agent + KG architecture but is closed-source SaaS-only. Their 'Autopilot' slider doesn't document a safety brake. Our safety envelope is in code you can read before you install."
  />

  <section class="mx-auto max-w-5xl px-6 py-20">
    <CompareTable competitorName="Ciroos" rows={rows} />

    <div class="mt-12 rounded-2xl border border-zinc-200/80 bg-zinc-50/60 p-8 dark:border-zinc-800/80 dark:bg-zinc-950/40">
      <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-50">
        Autonomy you can audit.
      </h2>
      <p class="mt-3 text-zinc-600 dark:text-zinc-400">
        Ciroos's "Automate / Augment / Autopilot" slider is good marketing. But what
        does the slider <em>do</em>? Their docs don't say. For an SRE evaluating
        whether to give a tool write access to production, that's the wrong answer.
      </p>
      <p class="mt-3 text-zinc-600 dark:text-zinc-400">
        CHA's safety envelope is named, scoped, and Apache-2.0. Whitelisted fixers
        have explicit GVR scopes. Protected namespaces are allowlisted out. Dry-run
        mode logs every fix without applying. AI-tier proposals require a signed-JWT
        click. Audit it before you install.
      </p>
    </div>
  </section>
</BaseLayout>
