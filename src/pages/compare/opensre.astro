---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CompareTable from '../../components/CompareTable.astro';
import { CLOUD_PROBES_TOTAL } from '../../data/product-facts';

const rows = [
  {
    dimension: 'Posture',
    cha: 'Autonomous K8s + cloud autopilot — detect → fix → re-verify',
    competitor: 'Investigation co-pilot — architecturally read-only',
  },
  {
    dimension: 'Mutation surface',
    cha: '5 policy-bounded fixers + AI-tier approval-gated proposals',
    competitor: 'Tracer: regex-blocks AWS mutations in code · swapnil: works on K8s but dormant',
  },
  {
    dimension: 'Closed-loop',
    cha: 'Yes — re-verify after every fix',
    competitor: 'No — neither project ships it',
  },
  {
    dimension: 'Multi-cloud breadth',
    cha: `${CLOUD_PROBES_TOTAL} probes across AWS / GCP / Azure`,
    competitor: 'Tracer: AWS read-only · swapnil: AWS credential validation only',
  },
  {
    dimension: 'Commercial support',
    cha: 'CHA-com paid tier with SLA, named TAM, multi-cluster',
    competitor: 'OSS-only — not commercializable',
  },
];
---

<BaseLayout
  title="CHA vs. OpenSRE (Tracer + swapnil)"
  description="Tracer's OpenSRE is architecturally read-only — they regex-block AWS mutations. swapnil's OpenSRE is solo and dormant. CHA is the only OSS-licensed K8s+cloud autopilot that ships closed-loop."
>
  <PageHero
    eyebrow="Compare &middot; OpenSRE"
    title="CHA vs. OpenSRE (Tracer + swapnil)"
    subtitle="Two OSS projects, neither ships closed-loop remediation. Tracer is a great investigation copilot but architecturally committed to read-only. swapnil's project is a solo author who went silent. CHA is the only OSS K8s+cloud autopilot with closed-loop as default."
  />

  <section class="mx-auto max-w-5xl px-6 py-20">
    <CompareTable competitorName="OpenSRE (combined)" rows={rows} />

    <div class="mt-12 rounded-2xl border border-zinc-200/80 bg-zinc-50/60 p-8 dark:border-zinc-800/80 dark:bg-zinc-950/40">
      <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-50">
        Tracer is great. They're solving a different problem.
      </h2>
      <p class="mt-3 text-zinc-600 dark:text-zinc-400">
        Tracer's OpenSRE is the most credible OSS investigation copilot in the space:
        141 tools, daily nightly releases, 5.7k GitHub stars, the CloudOpsBench
        benchmark. If you want an investigation copilot, they're an excellent
        choice — and their read-only commitment is the right posture for that
        product.
      </p>
      <p class="mt-3 text-zinc-600 dark:text-zinc-400">
        We're not competing on investigation accuracy. We're solving a different
        problem: <strong>remediate without paging a human, then verify the fix
        worked.</strong> Tracer's regex-blocked mutation surface means they
        architecturally cannot follow us there without rewriting the safety story
        they've shipped to their community.
      </p>
    </div>
  </section>
</BaseLayout>
