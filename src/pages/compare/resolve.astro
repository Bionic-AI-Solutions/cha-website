---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CompareTable from '../../components/CompareTable.astro';

const rows = [
  {
    dimension: 'Where it runs',
    cha: 'In your cluster — operator + CronJob + Deployment',
    competitor: 'Resolve SaaS + thin in-cluster Satellite gateway',
  },
  {
    dimension: 'Closed-loop remediation',
    cha: 'Yes — shipped today, default behavior',
    competitor: 'No — Resolve calls it "the next funding milestone"',
  },
  {
    dimension: 'Air-gap / sovereign / FedRAMP',
    cha: 'Yes — runs entirely in customer env',
    competitor: 'No — SaaS-only',
  },
  {
    dimension: 'Pricing transparency',
    cha: 'Published list prices for OSS / Team / Enterprise',
    competitor: 'Contact sales only',
  },
  {
    dimension: 'Open source',
    cha: 'Apache-2.0 — full OSS feature set',
    competitor: 'Proprietary',
  },
];
---

<BaseLayout
  title="CHA vs. Resolve AI"
  description="Resolve raised $190M at a $1.5B valuation and calls closed-loop 'the next funding milestone.' CHA ships closed-loop today, runs in-cluster including air-gap, and publishes list prices."
>
  <PageHero
    eyebrow="Compare &middot; Resolve AI"
    title="CHA vs. Resolve AI"
    subtitle="Resolve raised $190M at $1.5B and calls closed-loop 'the next funding milestone.' We ship it today. They're SaaS-only with no FedRAMP / sovereign story; we run inside your cluster including air-gap."
  />

  <section class="mx-auto max-w-5xl px-6 py-20">
    <CompareTable competitorName="Resolve AI" rows={rows} />

    <div class="mt-12 rounded-2xl border border-zinc-200/80 bg-zinc-50/60 p-8 dark:border-zinc-800/80 dark:bg-zinc-950/40">
      <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-50">
        We compete on architecture, not on funding-round PR.
      </h2>
      <p class="mt-3 text-zinc-600 dark:text-zinc-400">
        Resolve's funding announcement explicitly named closed-loop as a future
        milestone. We respect that — it's an honest engineering statement. But the
        difference between "shipped" and "next milestone" is the difference between
        being able to retire your on-call rotation and just being a fancier
        investigation copilot.
      </p>
      <p class="mt-3 text-zinc-600 dark:text-zinc-400">
        Verify our claims: clone the repo, run helm install, watch a DriftReport go
        from open to resolved without a human in the loop. We publish the code.
      </p>
    </div>
  </section>
</BaseLayout>
