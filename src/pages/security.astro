---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const safetyPillars = [
  {
    title: 'Air-gap by master switch',
    body:
      'Set cloud.enabled=false and CHA runs entirely in your cluster with zero external dependency. The K8s-native value (probes, fixers, ticketing) is unchanged. Verifiable in helm template output.',
  },
  {
    title: 'Sovereign-deployable',
    body:
      'No vendor SaaS. No telemetry exfiltration. CHA runs the same way in EU sovereign clouds, FedRAMP-trackable workloads, and on-prem regulated environments as it does on public EKS / GKE / AKS.',
  },
  {
    title: 'Cloud probes are read-only by design',
    body:
      'Every M1 / M2 cloud probe uses workload-identity-scoped read-only IAM. Cloud-resource mutation is deliberately deferred to M4 with a separate signed-approval envelope. Read the IAM policies in the Helm chart.',
  },
  {
    title: 'Whitelisted fixer set',
    body:
      'The OSS fixer set is exactly five named actions: StaleErrorPods, StuckJobsWithBadSecretRef, StuckRSPods, StuckCertificateRequests, TLSSecretMismatch. Each fixer is opt-in via Helm flag. Protected namespaces are allowlisted out by default.',
  },
  {
    title: 'Signed-JWT click-to-fix URLs (paid tiers)',
    body:
      'AI-tier fix proposals require human approval via signed-JWT URLs delivered to Slack or ticket. The approval-server enforces signature, expiry, one-time-use, and a per-(approver, action-class) rate budget (default 10 executions/hour per pair). Without the click, nothing mutates — unless you explicitly enable confidence-gated auto-merge (off by default; Wilson lower bound ≥0.95; the PR body is re-fetched and its Ed25519 attestation re-verified before merge; every safety gate must pass).',
  },
  {
    title: 'Dry-run mode',
    body:
      'Run --dry-run to log every fix CHA would have applied without applying it. The fix log is identical to production mode minus the mutation. Use this in your eval cycle before flipping fixers on.',
  },
  {
    title: 'Auditable by default',
    body:
      'Apache-2.0 source. Helm-rendered RBAC visible before install. DriftReport CRs are first-class audit objects. AI AuditEvents are hash-chained (prev_hash) in OSS pkg/audit; the Loki / OTLP / JSONL streaming sinks for compliance pipelines are paid.',
  },
  {
    title: 'Workload-identity auth',
    body:
      'IRSA on EKS, Workload Identity on GKE, AAD Workload Identity on AKS. No long-lived cloud credentials in CHA. Same IAM your cluster already uses — same audit trail.',
  },
  {
    title: 'Firecrawl external egress — key-gated, redacted query only (paid deep-RCA)',
    body:
      'The Firecrawl web-research step is active only when a Firecrawl API key is configured (K8s Secret `cha-firecrawl-key`); it can be disabled explicitly with `--firecrawl-enabled=false`. When active, CHA sends exactly one outbound HTTPS request per investigation to the Firecrawl API. The payload is a generic technical query synthesized by the LLM — no cluster namespace, hostname, IP address, pod name, or secret value is included. Without a key, the deep-RCA investigator falls back to cluster-only root-cause analysis (Describe + events + LLM synthesis) — no external call is made. The Firecrawl API key is sourced from a K8s Secret (never a flag literal). This is the only intentional external-egress exception in the paid tier.',
  },
];

const compliance = [
  { name: 'Apache-2.0 OSS license', detail: 'Audit every line of the safety envelope before installing.' },
  { name: 'SBOM (paid)', detail: 'SBOM (CycloneDX) pipeline ships in the v0.1.0-alpha.1 line (pre-alpha). First published SBOM artifacts pending CI billing restoration.' },
  { name: 'Signed artifacts', detail: 'OSS binary checksums are cosign-signed and Rekor-logged (checksums.txt.sigstore.json) on every release in the v0.1.0-alpha.1 line (pre-alpha). Container-image signing and CHA-com artifact signing pipelines are wired but their first signed artifacts are pending CI billing restoration.' },
  { name: 'No telemetry by default', detail: 'OSS tier ships with zero outbound telemetry. Opt in to phone-home, never the reverse.' },
  { name: 'Firecrawl egress disclosure (paid deep-RCA)', detail: 'The Firecrawl web-research step is active only when a Firecrawl API key is configured (K8s Secret `cha-firecrawl-key`); it can be disabled explicitly with `--firecrawl-enabled=false`. When active, one HTTPS call per investigation goes to the Firecrawl API. Only a generic LLM-synthesized technical question is sent — no namespace, hostname, IP, pod name, or secret. Without a key, the deep-RCA investigator performs cluster-only root-cause analysis — no external call is made. API key sourced from a K8s Secret only.' },
];
---

<BaseLayout
  title="CHA &mdash; Security &amp; safety envelope"
  description="Air-gap, sovereign, RBAC, fixer allowlist, signed approval URLs, cloud probes read-only by design. Audit every guardrail in the Apache-2.0 source."
>
  <PageHero
    eyebrow="Security"
    title="A safety envelope you can audit in the source."
    subtitle="Air-gap, sovereign, workload-identity, policy-bounded fixers, signed approval URLs. Every guardrail is in code you can read before you install."
  />

  <section class="mx-auto max-w-6xl px-6 py-20">
    <h2 class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50">
      The nine safety guarantees.
    </h2>
    <div class="mt-8 grid gap-5 md:grid-cols-2">
      {safetyPillars.map((p, i) => (
        <div class="rounded-2xl border border-zinc-200/80 bg-white p-6 shadow-sm dark:border-zinc-800/80 dark:bg-zinc-900/60">
          <div class="flex items-baseline gap-3">
            <span class="font-mono text-xs font-semibold text-accent-600 dark:text-accent-400">
              0{i + 1}
            </span>
            <h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-50">{p.title}</h3>
          </div>
          <p class="mt-2 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">{p.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="border-t border-zinc-200/70 bg-zinc-50/50 dark:border-zinc-800/70 dark:bg-zinc-950/60">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <h2 class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50">
        Compliance &amp; supply chain.
      </h2>
      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {compliance.map((c) => (
          <div class="rounded-xl border border-zinc-200/80 bg-white p-5 dark:border-zinc-800/80 dark:bg-zinc-900/60">
            <h3 class="text-base font-semibold text-zinc-900 dark:text-zinc-50">{c.name}</h3>
            <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">{c.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-6 py-20 text-center">
    <h2 class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50">
      Found something? Tell us.
    </h2>
    <p class="mt-3 text-zinc-600 dark:text-zinc-400">
      Security issues should go to <a class="font-medium text-accent-600 hover:text-accent-700 dark:text-accent-400" href="mailto:cha-security@baisoln.com">cha-security@baisoln.com</a>.
      We acknowledge within one business day.
    </p>
  </section>
</BaseLayout>
