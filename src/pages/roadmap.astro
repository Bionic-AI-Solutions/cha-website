---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const milestones = [
  {
    label: 'v1.7.0',
    status: 'Shipped — 2026-05-27',
    state: 'shipped',
    items: [
      'Drift-class expansion — agent investigation surface broadens from secret/credential drift to three new classes that page oncall in practice',
      'GitOpsDrift analyzer: Argo CD Application out-of-sync / Degraded + Flux Kustomization / HelmRelease Ready=False past grace; *Failed reasons escalate to critical',
      'WorkloadStateDrift analyzer: CNPG cluster phase, follower-degraded-while-healthy, primary switchover stuck; StatefulSet ordinal-zero gaps',
      'RBACDrift analyzer: wildcard verbs in user-defined Roles + unbound ServiceAccounts mounted by Pods; system roles excluded',
      'Reader ClusterRole extended for Argo/Flux CRDs + RBAC/ServiceAccount resources',
      'Helm wiring: analyzers.{gitopsDrift,workloadStateDrift,rbacDrift}.enabled toggles (default ON); CHA_ANALYZER_<NAME>=off env-gate',
      'Demo v3 (run-demo-v3.sh) — sales walkthrough leading with the AI SRE agent flow (T0 → T1 → T3 vault break-glass)',
      'CHA-com v1.7.0: LLMFixerMatcher (opt-in --ai-llm-fixer-matcher) — fixer selection becomes LLM-classified, falls back to keyword on error',
    ],
  },
  {
    label: 'v1.6.2',
    status: 'Shipped — 2026-05-27',
    state: 'shipped',
    items: [
      'Six new K8s probes: NodePressure, system DaemonSets, PendingPods, CrashLoopBackOff, ETCD, FailedMounts (now 12 K8s probes total)',
      '10 AWS cloud probes: RDS, EBS, EKS-cluster, EKS-nodegroups, IAM-roles, ALB, ACM, KMS, S3 public-access, VPC-subnets (off by default; cloud.enabled=false)',
      'Fixer safety nets: GitOps detection (Argo / Flux / Helm), spec.paused, CronJob.spec.suspend, cert-manager health gate',
      'Configurable critical-workloads list via env + annotation',
      'Lease-based leader election for HA watcher deployments (genuinely active in cluster as of v1.6.2)',
      'pkg/ai/redact: Kubernetes Event message scrubbing before LLM consumption',
      'Per-severity Slack repeat intervals — --slack-critical-repeat-interval splits warning vs critical cadence',
      'OpenProject MCP ticketing — auto-files unfixable diagnostics with dedup',
      'AI safety hardening (paid): patch-payload allow-list, investigation rate budget, cold-start mitigation, audit hash chain',
      'CHA-com paid v1.6.0: T0 narration, T1 fix proposer, T2 multi-step planner, T3 vault break-glass runbook with dual-approval, JWT-signed click-to-fix URLs, cha-com watch with JSONL audit log',
      'CronJob runtime caps: backoffLimit=1, activeDeadlineSeconds=120',
      'Chart unit tests (helm-unittest) wired into CI',
    ],
  },
  {
    label: 'v1.8.2 / v1.8.4',
    status: 'Shipped — 2026-05-28',
    state: 'shipped',
    items: [
      'Operator port to controller-runtime (Phase 1 + 1b): ClusterHealthAutopilot CRD + cha-operator manager reconciling watcher Deployment / CronJobs / SA, with Ready + WatcherRunning conditions (opt-in via operator.enabled)',
      'ConfigDrift analyzer (CRD multi-storedVersions, stuck rollouts, disagreeing pod config-checksums)',
      'CapacityDrift analyzer (HPA pinned at min/max past grace, AbleToScale=False, FailedGetResourceMetric, PVC expansion stuck)',
      'SecurityDrift analyzer (PSS-unlabeled/privileged namespaces, mutable :tag image refs, zero-NetworkPolicy namespaces)',
      'M2 K8s probes: Kong, HPA scaling, ArgoCD Application, Velero — each auto-skips when its CRD is absent; per-probe Helm toggles (probes.<name>.enabled)',
      '30 cloud probes — 10 each AWS / GCP / Azure — with live SDK wrappers (IRSA / GCP + AAD Workload Identity). AWS fetches every signal live; a few GCP/Azure signals (subnet IP-utilization, SQL storage-%, App Gateway backend health) honestly report "not measured" pending the cloud Monitoring API rather than silently passing',
      'Cloud-probe honesty hardening + operator BYO-ServiceAccount fix (v1.8.2)',
      'Paid tier deploys as a purely additive companion: OSS install + ai.enabled=true stands up a separate cha-com aiwatch Deployment (the AI-layered counterpart), OSS workloads untouched — see DEPLOYMENT.md (v1.8.4)',
      'CHA-com bumped to OSS v1.8.2 so the paid binary carries the full v1.8 detection surface alongside the T0–T3 AI tiers',
    ],
  },
  {
    label: 'v1.9 — v2.0',
    status: 'Roadmap',
    state: 'roadmap',
    items: [
      'Observability ingestion — Prometheus alerts as a CHA trigger (trigger-class C)',
      'External webhook ingestion — Vault rotations, cert-manager Issued, Cloudflare cert renewals (trigger-class E)',
      'Multi-cluster federation via ArgoCD ApplicationSet over the operator pattern',
      'Cloud-resource mutation (M4) with a separate signed-approval envelope, distinct from the K8s remediator role',
      'Redis-backed RunbookStore for HA approval-server (single-replica today)',
      'Public "incidents resolved without paging a human" benchmark',
    ],
  },
];
---

<BaseLayout
  title="CHA &mdash; Roadmap"
  description="Where CHA is going. v1.8 shipped (controller-runtime operator port, config/capacity/security drift classes, M2 K8s probes, 30 AWS/GCP/Azure cloud probes, and the purely-additive paid AI companion); v1.9+ cloud Monitoring-API signal wiring, operator Phase 1c, observability ingestion, multi-cluster federation, cloud-mutation envelope."
>
  <PageHero
    eyebrow="Roadmap"
    title="What's shipped, what's next."
    subtitle="v1.8 took the watcher to a controller-runtime operator, filled the remaining drift classes (config / capacity / security), added GCP/Azure cloud probes + the M2 K8s probe slice (Kong, HPA, ArgoCD, Velero), and made the paid AI tier a purely additive one-flag companion. CHA-com now rides the same v1.8.2 engine as OSS."
  />

  <section class="mx-auto max-w-5xl px-6 py-16">
    <div class="space-y-8">
      {milestones.map((m) => (
        <article class="rounded-2xl border border-white/10 bg-white/5 p-7">
          <header class="mb-4 flex flex-wrap items-baseline justify-between gap-3">
            <h3 class="text-2xl font-semibold text-white">{m.label}</h3>
            <span class={`rounded px-2 py-1 text-xs font-mono ${
              m.state === 'shipped'
                ? 'bg-emerald-900/40 text-emerald-300'
                : m.state === 'next'
                ? 'bg-cyan-900/40 text-cyan-300'
                : 'bg-slate-800 text-slate-400'
            }`}>{m.status}</span>
          </header>
          <ul class="space-y-2 text-sm leading-relaxed text-slate-300">
            {m.items.map((i) => (
              <li class="pl-4 -indent-4 before:content-['—'] before:mr-2 before:text-slate-500">
                {i}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <div class="mt-10 rounded-2xl border border-white/10 bg-white/5 p-6 text-sm text-slate-300">
      <p>
        Full design docs and the adversarial-review punch list live in the
        OSS repo at
        <a href="https://github.com/Bionic-AI-Solutions/cluster-health-autopilot/tree/main/docs/design"
           class="text-cyan-400 hover:text-cyan-300">docs/design/</a>.
      </p>
    </div>
  </section>
</BaseLayout>
