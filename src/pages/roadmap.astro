---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { loadChangelog } from '../data/changelog';
import { OSS_VERSION, PAID_VERSION } from '../data/product-facts';

// "Shipped" is GENERATED from the vendored CHANGELOG snapshots
// (scripts/sync-changelogs.sh) — this page can never list a release that
// does not exist in the real CHANGELOGs.
const oss = loadChangelog('oss');
const paid = loadChangelog('paid');
const asOf = oss.syncedDate;

// "Shipped" means TAGGED. The CHANGELOGs sometimes carry an entry for an
// untagged HEAD, so drop anything newer than the latest tag recorded in
// product-facts. If the tag isn't in the snapshot at all, the snapshot (or
// product-facts) is stale — fail the build instead of shipping a roadmap
// that contradicts the site.
//
// PRE-ALPHA RE-BASELINE (2026-06-18): the only CURRENT shipped release is
// v0.1.0-alpha.1 (a 0.x SemVer pre-release). Every prior 1.x tag was an
// internal pre-alpha iteration mis-numbered as 1.x and is now marked
// pre-release. We split the generated list at the 0.x / 1.x boundary so the
// page can feature the current 0.x release prominently and render the 1.x
// tail under a de-emphasized "pre-alpha iteration history" subsection — kept
// for honesty, never presented as the current/latest version. The split is
// still 100% generated from the CHANGELOG snapshots.
function shippedOnly(releases: typeof oss.releases, latestTag: string, repo: string) {
  const idx = releases.findIndex((r) => `v${r.version}` === latestTag);
  if (idx === -1) {
    throw new Error(
      `roadmap: ${repo} snapshot has no entry for ${latestTag} (product-facts latest tag). Run ./scripts/sync-changelogs.sh (or update product-facts.ts).`
    );
  }
  const shipped = releases.slice(idx);
  // Major version 0 = current pre-alpha line; 1+ = historical iterations.
  const major = (r: typeof oss.releases[number]) => parseInt(r.version.split('.')[0], 10);
  return {
    current: shipped.filter((r) => major(r) === 0),
    history: shipped.filter((r) => major(r) >= 1),
  };
}

const tracks = [
  { name: 'Open source — agentic-sre', tag: 'OSS', ...shippedOnly(oss.releases, OSS_VERSION, 'OSS') },
  { name: 'Srenix Enterprise', tag: 'Paid', ...shippedOnly(paid.releases, PAID_VERSION, 'paid') },
];

// Hand-curated open items — each verified against repo state on the sync
// date (grep before listing; nothing here has already shipped). P6.x refs
// point at the in-flight claims-fulfillment plan
// (Srenix Enterprise docs/plans/2026-06-11-adversarial-review-remediation.md).
// P6.1 (Loki/OTLP sinks), P6.3 (Jira), P6.4 (ServiceNow + multi-sink
// routing), P6.6 (hosted dashboard) and P6.7 (multi-cluster federation)
// all shipped — they are part of the v0.1.0-alpha.1 line and were removed
// from here on 2026-06-12. Cloud-aware RCA also shipped (join keys +
// matchers across both repos), now rolled into v0.1.0-alpha.1.
// RAG memory live + deep-RCA + tier chaining + ticket-close recording
// shipped in v0.2.0-alpha.1 (2026-06-19) — removed from open items.
const openItems = [
  { label: 'Cosign-signed container images + Srenix Enterprise artifacts', why: 'The SBOM (CycloneDX) + cosign signing pipeline shipped (P6.2) and OSS binary checksums are cosign-signed and Rekor-logged in the v0.1.0-alpha.1 line, but container-image and Srenix Enterprise artifact signing are still pending CI billing restoration', when: 'P6.2 — checksum signing live; image signing pending' },
  { label: 'Hosted playground', why: 'The "Try it now" path currently lands on quick-start; the live playground route is a coming-soon stub', when: 'P6.8 — in flight' },
  { label: 'OLM / OperatorHub publish', why: 'Operator bundle manifests + bundle-smoke CI gate exist; the bundle has not been published to OperatorHub', when: 'Next operator milestone' },
  { label: 'M7 phase 2 — per-probe dispatch', why: 'The GVRWatcher interface shipped (v0.1.0-alpha.1 line), but the watcher still runs every probe on every trigger (static watchedGVRs loop)', when: 'Q3 2026' },
  { label: 'M7 phase 3 — controller-runtime reconciler per probe', why: '~10-day effort + separate design doc', when: 'Q4 2026' },
  { label: 'Anonymized run-log opt-in collection', why: 'GTM day 14–90 milestone (no engineering blocker)', when: 'Product/marketing track' },
  { label: 'Multi-tenant SaaS variant', why: 'One binary serving N customer clusters; not yet designed, needs an RFC', when: 'Post first 3 paying customers' },
  { label: 'Deep-RCA Firecrawl egress domain allowlist (operator-configurable)', why: 'Current implementation uses default Firecrawl endpoint; operator-specified domain allowlist is a hardening follow-up', when: 'Next hardening sprint' },
];
---

<BaseLayout
  title="Srenix — Roadmap"
  description={`What's shipped and what's next on Agentic SRE. As of ${asOf}: OSS ${OSS_VERSION} and Enterprise ${PAID_VERSION} are live; the shipped list below is generated from the repos' CHANGELOGs, and the open-items list is hand-verified against repo state.`}
>
  <PageHero
    eyebrow="Roadmap"
    title="What's shipped, what's next."
    subtitle={`Shipped releases below are generated straight from the two repos' CHANGELOGs (last synced ${asOf}) — OSS is at ${OSS_VERSION}, the Enterprise Srenix Enterprise binary at ${PAID_VERSION}. The open-items list is hand-curated and verified against repo state on the same date.`}
  />

  <section class="mx-auto max-w-6xl px-6 py-16">

    <div class="mb-10 rounded-xl border border-amber-300/80 bg-amber-50 px-4 py-3 text-sm leading-relaxed text-amber-800 dark:border-amber-500/40 dark:bg-amber-500/10 dark:text-amber-300">
      <span class="font-semibold">Pre-alpha re-baseline.</span> The project
      re-baselined to 0.x-alpha (pre-launch). OSS is at
      <span class="font-mono">v0.1.0-alpha.1</span>; Enterprise Srenix Enterprise is at
      <span class="font-mono">v0.2.0-alpha.1</span> (adds RAG-live, deep-RCA, tier chaining). Earlier versions
      (OSS &le; <span class="font-mono">v1.26.3</span>, paid &le;
      <span class="font-mono">v1.22.4</span>) were internal pre-alpha
      iterations and are marked pre-release — nothing has shipped GA yet.
    </div>

    <!-- Current shipped release (generated) -->
    <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-50">Current release</h2>
    <div class="mt-1 h-0.5 w-8 rounded-full bg-accent-500"></div>
    <p class="mt-4 max-w-3xl text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
      The current shipped release per track. Every feature from the prior iterations is rolled into it.
      Every entry is parsed from the repo CHANGELOG at build time — nothing here is hand-copied.
    </p>

    <div class="mt-8 grid gap-8 lg:grid-cols-2">
      {tracks.map((track) => (
        <div>
          <div class="mb-4 flex items-baseline gap-3">
            <h3 class="text-base font-semibold text-zinc-900 dark:text-zinc-100">{track.name}</h3>
            <span class="rounded-full bg-accent-600/10 px-2 py-0.5 font-mono text-xs text-accent-700 dark:text-accent-400">{track.tag}</span>
          </div>
          <div class="space-y-4">
            {track.current.map((r) => (
              <article class="rounded-2xl border-2 border-accent-500/50 bg-white p-5 shadow-sm dark:border-accent-500/40 dark:bg-zinc-900/60">
                <header class="flex flex-wrap items-baseline justify-between gap-2">
                  <div class="flex items-center gap-2">
                    <h4 class="font-mono text-sm font-semibold text-zinc-900 dark:text-zinc-50">v{r.version}</h4>
                    <span class="rounded-full bg-accent-600/15 px-2 py-0.5 text-[11px] font-semibold text-accent-700 dark:text-accent-400">Current · pre-alpha</span>
                  </div>
                  <div class="flex items-center gap-2">
                    {r.note && (
                      <span class="rounded bg-amber-100 px-1.5 py-0.5 text-[11px] font-medium text-amber-800 dark:bg-amber-950/50 dark:text-amber-300">{r.note}</span>
                    )}
                    <time class="font-mono text-xs text-zinc-500 dark:text-zinc-400" datetime={r.date}>{r.date}</time>
                  </div>
                </header>
                {r.highlights.length > 0 && (
                  <ul class="mt-3 space-y-1.5 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
                    {r.highlights.map((h) => (
                      <li class="flex gap-2">
                        <span aria-hidden="true" class="mt-0.5 select-none text-accent-500">›</span>
                        <span>{h}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </article>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Pre-alpha iteration history (generated, de-emphasized) -->
    <h2 class="mt-20 text-lg font-semibold text-zinc-500 dark:text-zinc-400">Pre-alpha iteration history</h2>
    <div class="mt-1 h-0.5 w-8 rounded-full bg-zinc-300 dark:bg-zinc-700"></div>
    <p class="mt-4 max-w-3xl text-sm leading-relaxed text-zinc-500 dark:text-zinc-500">
      Releases numbered <span class="font-mono">1.x</span> before the 2026-06-18 re-baseline. These were
      internal pre-alpha iterations mis-numbered as 1.x; their work is folded into
      <span class="font-mono">v0.1.0-alpha.1</span> above. Kept here for transparency — these are
      <span class="font-medium">not</span> the current version. Generated from the CHANGELOGs.
    </p>

    <div class="mt-8 grid gap-8 lg:grid-cols-2">
      {tracks.map((track) => (
        <details class="group rounded-2xl border border-dashed border-zinc-200/80 bg-zinc-50/60 p-5 dark:border-zinc-800/80 dark:bg-zinc-900/30">
          <summary class="flex cursor-pointer items-center gap-3 text-sm font-medium text-zinc-500 dark:text-zinc-400">
            <span aria-hidden="true" class="select-none transition-transform group-open:rotate-90">›</span>
            <span>{track.name}</span>
            <span class="rounded-full bg-zinc-200/70 px-2 py-0.5 font-mono text-xs text-zinc-500 dark:bg-zinc-800 dark:text-zinc-400">{track.history.length} legacy 1.x</span>
          </summary>
          <div class="mt-4 space-y-3 opacity-80">
            {track.history.map((r) => (
              <article class="rounded-xl border border-zinc-200/70 bg-white/70 p-4 dark:border-zinc-800/70 dark:bg-zinc-900/40">
                <header class="flex flex-wrap items-baseline justify-between gap-2">
                  <h4 class="font-mono text-xs font-semibold text-zinc-500 dark:text-zinc-400">v{r.version} <span class="font-sans font-normal text-zinc-400 dark:text-zinc-500">(pre-rebaseline)</span></h4>
                  <div class="flex items-center gap-2">
                    {r.note && (
                      <span class="rounded bg-amber-100 px-1.5 py-0.5 text-[11px] font-medium text-amber-800 dark:bg-amber-950/50 dark:text-amber-300">{r.note}</span>
                    )}
                    <time class="font-mono text-[11px] text-zinc-400 dark:text-zinc-500" datetime={r.date}>{r.date}</time>
                  </div>
                </header>
                {r.highlights.length > 0 && (
                  <ul class="mt-2 space-y-1 text-xs leading-relaxed text-zinc-500 dark:text-zinc-500">
                    {r.highlights.map((h) => (
                      <li class="flex gap-2">
                        <span aria-hidden="true" class="mt-0.5 select-none text-zinc-400 dark:text-zinc-600">›</span>
                        <span>{h}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </article>
            ))}
          </div>
        </details>
      ))}
    </div>

    <!-- Open items (hand-curated, verified) -->
    <h2 class="mt-20 text-xl font-semibold text-zinc-900 dark:text-zinc-50">Open items</h2>
    <div class="mt-1 h-0.5 w-8 rounded-full bg-accent-500"></div>
    <p class="mt-4 max-w-3xl text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
      Living list of pending work as of {asOf}, each verified against repo state before listing.
      Engineering items reference the in-flight claims-fulfillment plan (P6.x); items on the
      product/marketing track don't block shipped capability.
    </p>
    <div class="mt-6 overflow-x-auto rounded-2xl border border-zinc-200/80 bg-white shadow-sm dark:border-zinc-800/80 dark:bg-zinc-900/60">
      <table class="w-full text-left text-sm">
        <thead class="border-b border-zinc-200 text-zinc-500 dark:border-zinc-800 dark:text-zinc-400">
          <tr>
            <th class="px-5 py-3 font-medium">Item</th>
            <th class="px-5 py-3 font-medium">Why it's still open</th>
            <th class="px-5 py-3 font-medium">When</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-100 text-zinc-600 dark:divide-zinc-800/60 dark:text-zinc-400">
          {openItems.map((i) => (
            <tr>
              <td class="px-5 py-3 font-medium text-zinc-900 dark:text-zinc-100">{i.label}</td>
              <td class="px-5 py-3">{i.why}</td>
              <td class="px-5 py-3 whitespace-nowrap font-mono text-xs text-accent-700 dark:text-accent-400">{i.when}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="mt-10 rounded-2xl border border-zinc-200/80 bg-zinc-50 p-6 text-sm leading-relaxed text-zinc-600 shadow-sm dark:border-zinc-800/80 dark:bg-zinc-900/40 dark:text-zinc-400">
      <p>
        Full design docs live in the OSS repo at
        <a href="https://github.com/srenix-ai/agentic-sre/tree/main/docs/design"
           class="text-accent-600 hover:text-accent-700 dark:text-accent-400 dark:hover:text-accent-300">docs/design/</a>.
        The consolidated forward-planning doc is at
        <a href="https://github.com/srenix-ai/agentic-sre/blob/main/docs/superpowers/plans/2026-06-09-srenix-consolidated-roadmap.md"
           class="text-accent-600 hover:text-accent-700 dark:text-accent-400 dark:hover:text-accent-300">docs/superpowers/plans/2026-06-09-srenix-consolidated-roadmap.md</a>.
      </p>
    </div>
  </section>
</BaseLayout>
