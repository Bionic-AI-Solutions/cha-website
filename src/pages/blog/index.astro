---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const posts = [
  {
    slug: 'from-cluster-health-analyzer-to-ai-sre',
    title: 'From cluster health analyzer to AI SRE.',
    excerpt:
      'Why we re-framed CHA (three new drift-class analyzers + an LLM-classified fixer matcher in the paid tier) and the safety envelope under the new name. Historical post — predates the pre-alpha re-baseline.',
    author: 'Salil Kadam',
    date: '2026-05-27',
    reading: '7 min',
  },
];
---

<BaseLayout
  title="CHA &mdash; Engineering blog"
  description="Engineering posts from named authors on probe design, the safety envelope, and the AI SRE repositioning."
>
  <PageHero
    eyebrow="Blog"
    title="Engineering blog"
    subtitle="Posts from named authors on probe design, the safety envelope, live-soak transcripts, and the AI SRE repositioning."
  />

  <section class="mx-auto max-w-3xl px-6 py-16">
    <div class="space-y-6">
      {posts.map((p) => (
        <a
          href={`/blog/${p.slug}/`}
          class="block rounded-2xl border border-zinc-200/80 bg-white p-7 shadow-sm transition hover:border-accent-400 dark:border-zinc-800/80 dark:bg-zinc-900/60 dark:hover:border-accent-500"
        >
          <h2 class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50">
            {p.title}
          </h2>
          <p class="mt-3 text-zinc-600 dark:text-zinc-400">{p.excerpt}</p>
          <div class="mt-4 flex items-center gap-4 text-sm text-zinc-500 dark:text-zinc-500">
            <span class="font-medium text-zinc-700 dark:text-zinc-300">{p.author}</span>
            <span>&middot;</span>
            <span>{p.date}</span>
            <span>&middot;</span>
            <span>{p.reading}</span>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-16 rounded-2xl border border-zinc-200/80 bg-zinc-50/60 p-7 dark:border-zinc-800/80 dark:bg-zinc-950/40">
      <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-50">
        In the queue
      </h2>
      <ul class="mt-3 space-y-2 text-sm text-zinc-600 dark:text-zinc-400">
        <li>&middot; Designing the cloud-probe framework for IRSA / WI / AAD-WI parity</li>
        <li>&middot; A live-soak transcript: synthetic ImagePullAuth drift, end-to-end</li>
        <li>&middot; Why detect &rarr; fix &rarr; re-verify is the right loop (and why everyone else stops at "fix")</li>
      </ul>
    </div>
  </section>
</BaseLayout>
