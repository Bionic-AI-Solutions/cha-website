---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PageHero from '../../components/PageHero.astro';
import {
  CLOUD_PROBES_AWS,
  CLOUD_PROBES_GCP,
  CLOUD_PROBES_AZURE,
  CLOUD_PROBES_TOTAL,
} from '../../data/product-facts';

// Disable env vars verified against catalog/cloud.go (RegisterCloudOSS):
// every cloud probe is gated on SRENIX_CLOUD_PROBE_<PROVIDER>_<NAME> != "off",
// rendered from the chart's cloud.<provider>.probes.<name> toggles. One key
// gates both EKS/GKE/AKS probes (control-plane + node groups: one asset).
const aws = [
  { name: 'RDS', checks: 'Instance/cluster status, storage %, multi-AZ, backup retention drift', disable: 'SRENIX_CLOUD_PROBE_AWS_RDS=off' },
  { name: 'EBSVolumes', checks: 'Orphan/unattached volumes, snapshot age', disable: 'SRENIX_CLOUD_PROBE_AWS_EBS=off' },
  { name: 'EKSControlPlane', checks: 'Version skew vs node groups, addon staleness', disable: 'SRENIX_CLOUD_PROBE_AWS_EKS=off' },
  { name: 'EKSNodeGroups', checks: 'Capacity, scaling activity, version drift', disable: 'SRENIX_CLOUD_PROBE_AWS_EKS=off' },
  { name: 'IAMRoles', checks: 'Trust policy drift on cluster service-account roles', disable: 'SRENIX_CLOUD_PROBE_AWS_IAM=off' },
  { name: 'ALBTargetHealth', checks: 'Unhealthy targets in Load Balancer Controller-managed target groups', disable: 'SRENIX_CLOUD_PROBE_AWS_ALB=off' },
  { name: 'ACMCertExpiry', checks: 'Certs expiring within 14 days', disable: 'SRENIX_CLOUD_PROBE_AWS_ACM=off' },
  { name: 'KMSKeys', checks: 'Pending-deletion KMS keys still referenced by cluster resources', disable: 'SRENIX_CLOUD_PROBE_AWS_KMS=off' },
  { name: 'S3BucketPublicAccess', checks: 'Public-ACL drift on buckets referenced by cluster IAM', disable: 'SRENIX_CLOUD_PROBE_AWS_S3=off' },
  { name: 'VPCSubnets', checks: 'Exhausted IP space affecting pod CIDR allocation', disable: 'SRENIX_CLOUD_PROBE_AWS_VPC=off' },
];

const gcp = [
  { name: 'CloudSQL', checks: 'Instance status; live disk-utilization % via the Cloud Monitoring API (skips the storage check when no recent datapoint, never reports 0%)', disable: 'SRENIX_CLOUD_PROBE_GCP_CLOUDSQL=off' },
  { name: 'PersistentDisks', checks: 'Disk health and attachment status', disable: 'SRENIX_CLOUD_PROBE_GCP_DISKS=off' },
  { name: 'GKEControlPlane', checks: 'Cluster status, control-plane version', disable: 'SRENIX_CLOUD_PROBE_GCP_GKE=off' },
  { name: 'GKENodePools', checks: 'Node pool status, version drift vs control plane', disable: 'SRENIX_CLOUD_PROBE_GCP_GKE=off' },
  { name: 'IAMServiceAccounts', checks: 'Workload Identity binding drift', disable: 'SRENIX_CLOUD_PROBE_GCP_IAM=off' },
  { name: 'Subnets', checks: 'Capacity-only: warns when a primary CIDR is smaller than /26 (threshold configurable via cloud.gcp.subnetsSmallPrefixThreshold + SRENIX_CLOUD_PROBE_GCP_SUBNETS_SMALL_PREFIX). GCP’s Compute API exposes no cheap used-IP count, so per-IP utilization is honestly not measured — review Network Analyzer for the real allocation ratio', disable: 'SRENIX_CLOUD_PROBE_GCP_SUBNETS=off' },
  { name: 'LoadBalancerBackends', checks: 'Backend health', disable: 'SRENIX_CLOUD_PROBE_GCP_LB=off' },
  { name: 'ManagedCertificates', checks: 'Managed-cert provisioning status and expiry', disable: 'SRENIX_CLOUD_PROBE_GCP_CERTS=off' },
  { name: 'GCSPublicAccess', checks: 'Public-access drift on buckets referenced by the cluster', disable: 'SRENIX_CLOUD_PROBE_GCP_GCS=off' },
  { name: 'KMSKeys', checks: 'Key state/policy drift on keys referenced by cluster resources', disable: 'SRENIX_CLOUD_PROBE_GCP_KMS=off' },
];

const azure = [
  { name: 'SQLDatabases', checks: 'Instance status, storage_percent (live Azure Monitor)', disable: 'SRENIX_CLOUD_PROBE_AZURE_SQL=off' },
  { name: 'Disks', checks: 'Disk health and attachment', disable: 'SRENIX_CLOUD_PROBE_AZURE_DISKS=off' },
  { name: 'AKSControlPlane', checks: 'Cluster status, control-plane version', disable: 'SRENIX_CLOUD_PROBE_AZURE_AKS=off' },
  { name: 'AKSNodePools', checks: 'Node pool status, version drift', disable: 'SRENIX_CLOUD_PROBE_AZURE_AKS=off' },
  { name: 'ManagedIdentities', checks: 'AAD Workload Identity binding drift', disable: 'SRENIX_CLOUD_PROBE_AZURE_IDENTITIES=off' },
  { name: 'Subnets', checks: 'Live used-IP measurement: counts every subnet-attached resource (NIC IP configs, AppGW IP configs, IP-config profiles, private endpoints) so available = total − used', disable: 'SRENIX_CLOUD_PROBE_AZURE_SUBNETS=off' },
  { name: 'AppGatewayBackends', checks: 'Live BackendHealth LRO', disable: 'SRENIX_CLOUD_PROBE_AZURE_APPGW=off' },
  { name: 'Certificates', checks: 'Cert expiry', disable: 'SRENIX_CLOUD_PROBE_AZURE_CERTS=off' },
  { name: 'StoragePublicAccess', checks: 'Public-access policy drift', disable: 'SRENIX_CLOUD_PROBE_AZURE_STORAGE=off' },
  { name: 'KeyVaults', checks: 'Key/secret expiry', disable: 'SRENIX_CLOUD_PROBE_AZURE_KEYVAULTS=off' },
];

// Build-time drift assertions: each provider table must match the canonical counts.
if (aws.length !== CLOUD_PROBES_AWS) {
  throw new Error(
    `count drift: docs/cloud-probes.astro lists ${aws.length} AWS probes but product-facts CLOUD_PROBES_AWS=${CLOUD_PROBES_AWS}`
  );
}
if (gcp.length !== CLOUD_PROBES_GCP) {
  throw new Error(
    `count drift: docs/cloud-probes.astro lists ${gcp.length} GCP probes but product-facts CLOUD_PROBES_GCP=${CLOUD_PROBES_GCP}`
  );
}
if (azure.length !== CLOUD_PROBES_AZURE) {
  throw new Error(
    `count drift: docs/cloud-probes.astro lists ${azure.length} Azure probes but product-facts CLOUD_PROBES_AZURE=${CLOUD_PROBES_AZURE}`
  );
}

const cloudRows = [
  { provider: 'AWS', count: String(CLOUD_PROBES_AWS), enable: 'cloud.aws.enabled: true', auth: 'IRSA (no long-lived keys)' },
  { provider: 'GCP', count: String(CLOUD_PROBES_GCP), enable: 'cloud.gcp.enabled: true', auth: 'GCP Workload Identity' },
  { provider: 'Azure', count: String(CLOUD_PROBES_AZURE), enable: 'cloud.azure.enabled: true', auth: 'AAD Workload Identity' },
];

const sections = [
  { title: `AWS probes (${CLOUD_PROBES_AWS})`, probes: aws },
  { title: `GCP probes (${CLOUD_PROBES_GCP})`, probes: gcp },
  { title: `Azure probes (${CLOUD_PROBES_AZURE})`, probes: azure },
];
---

<DocsLayout
  title="Srenix &mdash; Cloud Probes"
  description={`${CLOUD_PROBES_TOTAL} cloud probes across AWS, GCP, and Azure. Workload-identity auth only. Enable per-provider in Helm values.`}
  topic="Cloud Probes"
>
  <PageHero
    eyebrow="Docs"
    title="Cloud Probes"
    subtitle={`${CLOUD_PROBES_TOTAL} probes across AWS, GCP, and Azure. Workload-identity auth only — no long-lived credentials. All off by default; enable per-provider.`}
  />

  <section class="mx-auto max-w-5xl space-y-16 px-6 py-16">

    <div>
      <p class="text-base leading-relaxed text-zinc-600 dark:text-zinc-400">
        Cloud probes run alongside the K8s probes on every cycle. They use the same workload-identity credentials your cluster already has — IRSA on EKS, GCP Workload Identity on GKE, AAD Workload Identity on AKS. No cloud credentials are stored in Srenix.
      </p>

      <div class="mt-6 overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="border-b border-zinc-200 dark:border-zinc-800">
              <th class="py-2 pr-6 text-left font-medium text-zinc-500 dark:text-zinc-400">Provider</th>
              <th class="py-2 pr-6 text-left font-medium text-zinc-500 dark:text-zinc-400">Probes</th>
              <th class="py-2 pr-6 text-left font-medium text-zinc-500 dark:text-zinc-400">Enable (Helm)</th>
              <th class="py-2 text-left font-medium text-zinc-500 dark:text-zinc-400">Auth</th>
            </tr>
          </thead>
          <tbody>
            {cloudRows.map((r) => (
              <tr class="border-b border-zinc-100 dark:border-zinc-800/60">
                <td class="py-3 pr-6 font-semibold text-zinc-900 dark:text-zinc-100">{r.provider}</td>
                <td class="py-3 pr-6 text-zinc-600 dark:text-zinc-400">{r.count}</td>
                <td class="py-3 pr-6 font-mono text-xs text-zinc-500 dark:text-zinc-400">{r.enable}</td>
                <td class="py-3 text-zinc-600 dark:text-zinc-400">{r.auth}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="mt-4 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 dark:border-amber-900/50 dark:bg-amber-950/30">
        <p class="text-sm text-amber-800 dark:text-amber-300">
          Cloud probes are <strong>off by default</strong>. Enable with <code class="font-mono">--set cloud.enabled=true --set cloud.aws.enabled=true</code> (or equivalent for GCP/Azure) — <code class="font-mono">cloud.enabled</code> is the master switch; each provider is toggled independently underneath it. Within an enabled provider, <strong>every probe is individually disablable</strong>: set <code class="font-mono">cloud.&lt;provider&gt;.probes.&lt;name&gt;: false</code> (rendered as <code class="font-mono">SRENIX_CLOUD_PROBE_&lt;PROVIDER&gt;_&lt;NAME&gt;=off</code>; one key gates both EKS/GKE/AKS control-plane + node-group probes). The K8s-only value is unchanged if you never enable cloud probes.
        </p>
      </div>
    </div>

    {sections.map((s) => (
      <div>
        <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-50">{s.title}</h2>
        <div class="mt-1 h-0.5 w-8 rounded-full bg-accent-500"></div>
        <div class="mt-6 overflow-x-auto">
          <table class="w-full border-collapse text-sm">
            <thead>
              <tr class="border-b border-zinc-200 dark:border-zinc-800">
                <th class="py-2 pr-6 text-left font-medium text-zinc-500 dark:text-zinc-400">Probe</th>
                <th class="py-2 pr-6 text-left font-medium text-zinc-500 dark:text-zinc-400">What it checks</th>
                <th class="py-2 text-left font-medium text-zinc-500 dark:text-zinc-400">Disable env var</th>
              </tr>
            </thead>
            <tbody>
              {s.probes.map((p) => (
                <tr class="border-b border-zinc-100 dark:border-zinc-800/60">
                  <td class="py-3 pr-6 font-mono text-xs font-semibold text-zinc-900 dark:text-zinc-100">{p.name}</td>
                  <td class="py-3 pr-6 text-zinc-600 dark:text-zinc-400">{p.checks}</td>
                  <td class="py-3 font-mono text-xs text-zinc-400 dark:text-zinc-500">{p.disable}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    ))}

  </section>
</DocsLayout>
