---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { loadHelmSnapshot } from '../../data/helm-values';

// Generated from the vendored chart snapshot (src/data/helm-values.snapshot.yaml,
// created by scripts/sync-helm-values.sh). Every key below exists in the real
// chart's values.yaml — loadHelmSnapshot() throws at build time if the
// snapshot is missing, empty, or unparsable.
const { chartVersion, syncedDate, groups } = loadHelmSnapshot();
---

<DocsLayout
  title="Srenix &mdash; Helm Reference"
  description="Every Helm values.yaml option for Agentic SRE, generated from the chart's own values file."
  topic="Helm Reference"
>
  <PageHero
    eyebrow="Docs"
    title="Helm Reference"
    subtitle={`Every values.yaml option, generated from chart v${chartVersion} (synced ${syncedDate}). Full chart source at charts/agentic-sre/ in the GitHub repo.`}
  />

  <section class="mx-auto max-w-5xl space-y-14 px-6 py-16">

    <div>
      <p class="text-base leading-relaxed text-zinc-600 dark:text-zinc-400">
        Install with defaults first — most options have safe defaults. Add cloud probes, ticketing, and AI tiers incrementally as you need them. This reference is generated directly from the chart's{' '}
        <a
          href="https://github.com/Srenix/agentic-sre/blob/main/charts/agentic-sre/values.yaml"
          class="text-accent-600 hover:text-accent-700 dark:text-accent-400 dark:hover:text-accent-300"
          target="_blank"
          rel="noopener noreferrer"
        >
          values.yaml
        </a>{' '}
        (chart v{chartVersion}), so every key listed here exists in the chart.
      </p>
    </div>

    {groups.map((g) => (
      <div>
        <h2 class="font-mono text-xl font-semibold text-zinc-900 dark:text-zinc-50">{g.name}</h2>
        <div class="mt-1 h-0.5 w-8 rounded-full bg-accent-500"></div>
        {g.desc && (
          <p class="mt-3 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">{g.desc}</p>
        )}
        <div class="mt-6 overflow-x-auto">
          <table class="w-full border-collapse text-sm">
            <thead>
              <tr class="border-b border-zinc-200 dark:border-zinc-800">
                <th class="py-2 pr-6 text-left font-medium text-zinc-500 dark:text-zinc-400">Key</th>
                <th class="py-2 pr-6 text-left font-medium text-zinc-500 dark:text-zinc-400">Default</th>
                <th class="py-2 text-left font-medium text-zinc-500 dark:text-zinc-400">Description</th>
              </tr>
            </thead>
            <tbody>
              {g.rows.map((r) => (
                <tr class="border-b border-zinc-100 dark:border-zinc-800/60">
                  <td class="py-3 pr-6 font-mono text-xs font-medium text-zinc-900 dark:text-zinc-100">{r.key}</td>
                  <td class="py-3 pr-6 font-mono text-xs text-zinc-500 dark:text-zinc-400">{r.default}</td>
                  <td class="py-3 text-zinc-600 dark:text-zinc-400">{r.desc}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    ))}

  </section>
</DocsLayout>
