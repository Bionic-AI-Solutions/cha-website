---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { OSS_ANALYZERS } from '../../data/product-facts';

// Disable env vars verified against catalog/catalog.go (RegisterOSS): every
// default-on analyzer is gated on CHA_ANALYZER_<NAME> != "off", and the chart
// renders the matching analyzers.<name>.enabled toggle (values.yaml).
const diagnostic = [
  { name: 'SecretKeyMissing', detects: 'Pod in CreateContainerConfigError — names the missing key, consuming Deployment, and owning ExternalSecret', severity: 'Critical', disable: 'CHA_ANALYZER_SECRET_KEY_MISSING=off' },
  { name: 'FailingExternalSecrets', detects: 'ExternalSecret with Ready=False — surfaces the controller error message including the specific missing Vault property', severity: 'Warning', disable: 'CHA_ANALYZER_FAILING_EXTERNAL_SECRETS=off' },
  { name: 'ProactiveSecretKeyCheck', detects: 'Workload env references to Secret keys that don\'t exist yet — fires before the pod crashes', severity: 'Warning', disable: 'CHA_ANALYZER_PROACTIVE_SECRET_KEY_CHECK=off' },
  { name: 'UnprovisionedSecret', detects: 'Workload references a Secret with no ExternalSecret provisioning it', severity: 'Warning', disable: 'CHA_ANALYZER_UNPROVISIONED_SECRET=off' },
  { name: 'ImagePullAuth', detects: 'Pod in ImagePullBackOff with kubelet auth-failure signals (401, denied, unauthorized)', severity: 'Critical', disable: 'CHA_ANALYZER_IMAGE_PULL_AUTH=off' },
  { name: 'CertExpiry', detects: 'cert-manager Certificate not Ready, expiring within 14 days, or already expired', severity: 'Critical / Warning', disable: 'CHA_ANALYZER_CERT_EXPIRY=off' },
  { name: 'TLSSecretMismatch', detects: 'Ingress points at an expired Secret while cert-manager renews into a different Secret (two-Secret naming drift)', severity: 'Warning', disable: 'CHA_ANALYZER_TLS_SECRET_MISMATCH=off' },
  { name: 'VaultPathMissing', optIn: true, detects: 'Queries Vault directly to catch drift before ESO\'s next refresh. Apache-2.0; you provide the Vault client. Paid tier auto-wires from your Vault config.', severity: 'Warning', disable: '— (opt-in, not default-registered)' },
  { name: 'DNSChainDrift', detects: 'Cloudflare DNS → cluster ingress LB → Ingress host → Service → ready Endpoints. Emits the highest broken layer per host. Also detects multiple Ingresses claiming the same host+path combination.', severity: 'Warning', disable: 'CHA_ANALYZER_DNS_CHAIN_DRIFT=off' },
  { name: 'NetworkPolicyProposer', detects: 'User namespaces with no NetworkPolicy on CNIs that enforce NetworkPolicy — emits a ready-to-apply policy YAML per uncovered namespace. Silent on non-enforcing CNIs (e.g. k3s Flannel-only)', severity: 'Warning', disable: 'CHA_ANALYZER_NETPOL_PROPOSER=off' },
];

const drift = [
  { name: 'GitOpsDrift', detects: 'Resources that have drifted from their GitOps-managed desired state', disable: 'CHA_ANALYZER_GITOPS_DRIFT=off' },
  { name: 'WorkloadStateDrift', detects: 'CNPG cluster phase and primary-switchover detection, StatefulSet pod-0 absence or not-ready', disable: 'CHA_ANALYZER_WORKLOAD_STATE_DRIFT=off' },
  { name: 'RBACDrift', detects: 'ClusterRoleBinding/RoleBinding changes not reflected in expected state', disable: 'CHA_ANALYZER_RBAC_DRIFT=off' },
  { name: 'ConfigDrift', detects: 'CRD storage version drift, stuck Deployment rollout (generation vs observedGeneration), and Helm checksum annotation divergence across pods', disable: 'CHA_ANALYZER_CONFIG_DRIFT=off' },
  { name: 'CapacityDrift', detects: 'Resource request/limit ratios that have drifted from baseline', disable: 'CHA_ANALYZER_CAPACITY_DRIFT=off' },
  { name: 'SecurityDrift', detects: 'Missing Pod Security Standards enforcement labels, mutable image tags (no digest pin), and NetworkPolicy coverage gaps per namespace. Mutable-tag severity is registry-dependent: Info for trusted upstream registries (quay.io, gcr.io, ghcr.io, registry.k8s.io, docker.io/library, etc.), Warning for untrusted/in-house registries (tunable via CHA_DIGEST_PIN_UNTRUSTED_SEVERITY)', disable: 'CHA_ANALYZER_SECURITY_DRIFT=off' },
];

const workload = [
  { name: 'LogPatternMatcher', detects: 'Recent Events matching high-signal failure patterns (ImagePullBackOff, OOMKilled, VolumeAttachFailed, ProbeFailed, RBAC Forbidden) — dedup\'d per (object, pattern)', disable: 'CHA_ANALYZER_LOG_PATTERN_MATCHER=off' },
  { name: 'DisruptionDrift', detects: 'PDB: disruptionsAllowed=0 past 5 min; Indexed-Job failed indexes past 10 min; ResourceQuota at 100% past 1h', disable: 'CHA_ANALYZER_DISRUPTION_DRIFT=off' },
  { name: 'OOMKillRecurrence', detects: 'Pod with ≥3 OOMKilled restarts in 24h — signals a persistent memory sizing issue', disable: 'CHA_ANALYZER_OOMKILL_RECURRENCE=off' },
  { name: 'PVOrphan', detects: 'PersistentVolume Released >7 days — still billing on the underlying cloud disk', disable: 'CHA_ANALYZER_PV_ORPHAN=off' },
  { name: 'CronJobStuck', detects: 'Warning: >24h since last success or suspended CronJob; Critical: never succeeded', disable: 'CHA_ANALYZER_CRONJOB_STUCK=off' },
];

const paid = [
  { name: 'VaultPathDriftPro', detects: 'Extended Vault path analysis with auto-wired client and cross-namespace drift' },
  { name: 'CertificateChainAnomaly', detects: 'Full cert chain validation including intermediate CAs and trust anchors' },
  { name: 'MultiClusterDrift', detects: 'Cross-cluster state divergence across federated or ArgoCD-managed clusters' },
  { name: 'StatefulSetReplicaPressure', detects: 'StatefulSet rolling-update stalls and replica pressure patterns' },
];

// Build-time drift assertion: the OSS tables sum to OSS_ANALYZERS + 1 because
// VaultPathMissing is listed (marked opt-in) but intentionally NOT counted in
// OSS_ANALYZERS — it isn't default-registered (needs an operator-supplied
// Vault client). See src/data/product-facts.ts.
const ossRowCount = diagnostic.length + drift.length + workload.length;
if (ossRowCount !== OSS_ANALYZERS + 1) {
  throw new Error(
    `count drift: docs/analyzers.astro lists ${ossRowCount} OSS analyzer rows but expected OSS_ANALYZERS + 1 opt-in row = ${OSS_ANALYZERS + 1}`
  );
}
---

<DocsLayout
  title="CHA &mdash; Analyzers"
  description={`${OSS_ANALYZERS} OSS analyzers run after every probe cycle — diagnostic, drift-class, log/workload — plus opt-in VaultPathMissing. 4 additional analyzers in the paid tier.`}
  topic="Analyzers"
>
  <PageHero
    eyebrow="Docs"
    title="Analyzers"
    subtitle="Analyzers run after every probe cycle. All are read-only. Findings attach to DriftReport CRs and route to Slack, Alertmanager, and ticketing sinks."
  />

  <section class="mx-auto max-w-5xl space-y-16 px-6 py-16">

    <div>
      <p class="text-base leading-relaxed text-zinc-600 dark:text-zinc-400">
        Analyzers inspect the raw Kubernetes API state — they don't call external services unless an integration is configured. Each analyzer emits a finding with a severity, a human-readable summary, and actionable remediation hints.
      </p>
      <div class="mt-4 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 dark:border-amber-900/50 dark:bg-amber-950/30">
        <p class="text-sm text-amber-800 dark:text-amber-300">
          <strong>Disable any analyzer</strong> with <code class="font-mono">CHA_ANALYZER_NAME=off</code> or the per-analyzer Helm toggle (<code class="font-mono">analyzers.name.enabled: false</code>).
        </p>
      </div>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-50">Diagnostic analyzers ({diagnostic.length})</h2>
      <div class="mt-1 h-0.5 w-8 rounded-full bg-accent-500"></div>
      <div class="mt-6 overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="border-b border-zinc-200 dark:border-zinc-800">
              <th class="py-2 pr-6 text-left font-medium text-zinc-500 dark:text-zinc-400">Analyzer</th>
              <th class="py-2 pr-6 text-left font-medium text-zinc-500 dark:text-zinc-400">What it detects</th>
              <th class="py-2 pr-6 text-left font-medium text-zinc-500 dark:text-zinc-400">Severity</th>
              <th class="py-2 text-left font-medium text-zinc-500 dark:text-zinc-400">Disable env var</th>
            </tr>
          </thead>
          <tbody>
            {diagnostic.map((r) => (
              <tr class="border-b border-zinc-100 dark:border-zinc-800/60">
                <td class="py-3 pr-6 font-mono text-xs font-semibold text-zinc-900 dark:text-zinc-100">
                  {r.name}
                  {r.optIn && (
                    <span class="ml-2 inline-block rounded-full border border-amber-300 bg-amber-50 px-2 py-0.5 font-sans text-[10px] font-medium text-amber-700 dark:border-amber-800 dark:bg-amber-950/40 dark:text-amber-400">opt-in — not in the {OSS_ANALYZERS} default-on count</span>
                  )}
                </td>
                <td class="py-3 pr-6 text-zinc-600 dark:text-zinc-400">{r.detects}</td>
                <td class="py-3 pr-6 font-mono text-xs text-zinc-500 dark:text-zinc-400">{r.severity}</td>
                <td class="py-3 font-mono text-xs text-zinc-400 dark:text-zinc-500">{r.disable}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-50">Drift-class analyzers ({drift.length})</h2>
      <div class="mt-1 h-0.5 w-8 rounded-full bg-accent-500"></div>
      <div class="mt-6 overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="border-b border-zinc-200 dark:border-zinc-800">
              <th class="py-2 pr-6 text-left font-medium text-zinc-500 dark:text-zinc-400">Analyzer</th>
              <th class="py-2 pr-6 text-left font-medium text-zinc-500 dark:text-zinc-400">What it detects</th>
              <th class="py-2 text-left font-medium text-zinc-500 dark:text-zinc-400">Disable env var</th>
            </tr>
          </thead>
          <tbody>
            {drift.map((r) => (
              <tr class="border-b border-zinc-100 dark:border-zinc-800/60">
                <td class="py-3 pr-6 font-mono text-xs font-semibold text-zinc-900 dark:text-zinc-100">{r.name}</td>
                <td class="py-3 pr-6 text-zinc-600 dark:text-zinc-400">{r.detects}</td>
                <td class="py-3 font-mono text-xs text-zinc-400 dark:text-zinc-500">{r.disable}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-50">Log / workload analyzers ({workload.length})</h2>
      <div class="mt-1 h-0.5 w-8 rounded-full bg-accent-500"></div>
      <div class="mt-6 overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="border-b border-zinc-200 dark:border-zinc-800">
              <th class="py-2 pr-6 text-left font-medium text-zinc-500 dark:text-zinc-400">Analyzer</th>
              <th class="py-2 pr-6 text-left font-medium text-zinc-500 dark:text-zinc-400">What it detects</th>
              <th class="py-2 text-left font-medium text-zinc-500 dark:text-zinc-400">Disable env var</th>
            </tr>
          </thead>
          <tbody>
            {workload.map((r) => (
              <tr class="border-b border-zinc-100 dark:border-zinc-800/60">
                <td class="py-3 pr-6 font-mono text-xs font-semibold text-zinc-900 dark:text-zinc-100">{r.name}</td>
                <td class="py-3 pr-6 text-zinc-600 dark:text-zinc-400">{r.detects}</td>
                <td class="py-3 font-mono text-xs text-zinc-400 dark:text-zinc-500">{r.disable}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-50">Paid-tier analyzers ({paid.length})</h2>
      <div class="mt-1 h-0.5 w-8 rounded-full bg-accent-500"></div>
      <p class="mt-4 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
        The <code class="font-mono">cha-com</code> paid binary adds four additional analyzers via the same <code class="font-mono">pkg/registry</code> interface as OSS analyzers. They do not have per-analyzer env toggles; registration is wiring-driven — e.g. <code class="font-mono">VaultPathDriftPro</code> registers only when Vault credentials (<code class="font-mono">VAULT_ADDR</code> plus a token or K8s-auth role) are configured.
      </p>
      <div class="mt-6 overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="border-b border-zinc-200 dark:border-zinc-800">
              <th class="py-2 pr-6 text-left font-medium text-zinc-500 dark:text-zinc-400">Analyzer</th>
              <th class="py-2 text-left font-medium text-zinc-500 dark:text-zinc-400">What it detects</th>
            </tr>
          </thead>
          <tbody>
            {paid.map((r) => (
              <tr class="border-b border-zinc-100 dark:border-zinc-800/60">
                <td class="py-3 pr-6 font-mono text-xs font-semibold text-zinc-900 dark:text-zinc-100">{r.name}</td>
                <td class="py-3 text-zinc-600 dark:text-zinc-400">{r.detects}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

  </section>
</DocsLayout>
