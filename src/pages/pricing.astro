---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import {
  K8S_PROBES,
  CLOUD_PROBES_AWS,
  CLOUD_PROBES_GCP,
  CLOUD_PROBES_AZURE,
} from '../data/product-facts';

const tiers = [
  {
    name: 'Srenix Open Core',
    audience: 'The cluster runtime — SREs, platform engineers, hobbyists',
    price: 'Free',
    priceNote: 'Apache-2.0 license',
    cta: { label: 'Helm install', href: 'https://github.com/srenix-ai/agentic-sre' },
    highlight: false,
    features: [
      `All ${K8S_PROBES} K8s probes — Ceph, Postgres, Nodes, PVCs, Critical services, Endpoints, NodePressure, DaemonSets, PendingPods, CrashLoopBackOff, ETCD, FailedMounts, Kong, KongRoutes, GPUNodes, HPA, ArgoCD, Velero, Traefik routes, k3s local-path + datastore`,
      `${CLOUD_PROBES_AWS} AWS cloud probes (off-by-default, opt-in via cloud.enabled) — RDS, EBS, EKS control-plane + node groups, IAM, ALB, ACM, KMS, S3, VPC + IRSA`,
      `${CLOUD_PROBES_GCP} GCP cloud probes — Cloud SQL (live Cloud Monitoring disk utilization), Persistent Disk, GKE control-plane + node pools, IAM SA, Subnet, LB backends, Managed certs, GCS public-access, KMS. Workload-Identity auth.`,
      `${CLOUD_PROBES_AZURE} Azure cloud probes — SQL DB (live storage_percent), Disk, AKS control-plane + node pools, Identity, Subnet (live IP-pool count), AppGW (live BackendHealth LRO), Certificates, Storage public-access, Key Vault. AAD Workload Identity native.`,
      'All 5 policy-bounded fixers + GitOps / paused / suspended safety gates',
      'Lease-based leader election (HA-ready watcher)',
      'OpenProject MCP ticketing',
      'Slack 3-channel + Alertmanager routing, per-severity repeat intervals',
      'Snapshot + offline mode, air-gap deployment',
      'Apache-2.0 — audit the safety envelope',
    ],
  },
  {
    name: 'AI SRE Team',
    audience: 'Small teams adopting an autonomous SRE agent',
    price: '$X',
    priceNote: 'per cluster / month',
    cta: { label: 'Contact us', href: 'mailto:hello@srenix.ai' },
    highlight: true,
    features: [
      'Everything in OSS',
      'T0 enricher — LLM context on every DriftReport',
      'T1 fix proposer — LLM-augmented fix suggestions',
      'Signed-JWT approval-server (click-to-fix)',
      'Dashboard (self-hosted)',
      'Email support',
    ],
  },
  {
    name: 'AI SRE Enterprise',
    audience: 'Enterprise SREs running fleets of clusters',
    price: '$Y',
    priceNote: 'per cluster / month',
    cta: { label: 'Contact sales', href: 'mailto:sales@srenix.ai' },
    highlight: false,
    features: [
      'Everything in Team',
      'T2 multi-step planner',
      'T3 Vault runbook proposer',
      'Confidence-gated auto-merge — Wilson lower bound ≥ 0.95 on class success-rate, Ed25519 attestation verified, circuit breaker closed. Off by default',
      'RAG outcome memory (Qdrant) — every fix outcome grounds the next proposal',
      'Ed25519-signed approvals + cosign-style PR attestation',
      'Audit-bundle export — SOC2-friendly evidence pack (manifest + audit.jsonl + outcomes.jsonl), local-only',
      'Approve-class policies — approve / deny / silence a whole finding class, not just one DriftReport',
      'Cloud-aware RCA — deterministic K8s↔cloud correlation grounding T0/T1 prompts (MVP)',
      'Jira / ServiceNow ticketing',
      'Multi-cluster federation',
      'SLA support + named TAM',
    ],
  },
  {
    name: 'Federal / Sovereign',
    audience: 'FedRAMP / EU sovereign / regulated buyers',
    price: 'Contact',
    priceNote: 'sales',
    cta: { label: 'Contact sales', href: 'mailto:fed@srenix.ai' },
    highlight: false,
    features: [
      'Everything in Enterprise',
      'Air-gap installer',
      'SBOM + cosign-signed images (OSS binary checksums cosign-signed; container-image + Srenix Enterprise artifact signing pending CI billing restoration)',
      'Independent audit reports',
      'Sovereign deployment patterns',
      'Dedicated security engineering',
    ],
  },
];
---

<BaseLayout
  title="Srenix &mdash; Pricing"
  description="Flat per-cluster pricing. No per-investigation surprises. OSS includes all probes and fixers; paid tiers add LLM-augmented investigation, ticketing, and multi-cluster federation."
>
  <PageHero
    eyebrow="Pricing"
    title="Transparent, flat per-cluster pricing."
    subtitle="No per-investigation pricing. No 'contact sales' wall for the open-core engine. Helm install, evaluate, upgrade to the AI SRE tier when you're ready to put an agent on top."
  />

  <section class="mx-auto max-w-7xl px-6 pt-10">
    <div class="rounded-xl border border-amber-300/80 bg-amber-50 px-4 py-3 text-sm text-amber-800 dark:border-amber-500/40 dark:bg-amber-500/10 dark:text-amber-300">
      <span class="font-semibold">Pre-alpha.</span> Both products are at
      <span class="font-mono">v0.1.0-alpha.1</span> (pre-launch). Pricing and
      tiers below are pre-launch and may change before GA; versions are
      pre-alpha and not yet generally available.
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-6 py-20">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {tiers.map((tier) => (
        <div
          class:list={[
            'flex flex-col rounded-2xl border bg-white p-7 shadow-sm dark:bg-zinc-900/60',
            tier.highlight
              ? 'border-accent-600 ring-1 ring-accent-600/30 dark:border-accent-500'
              : 'border-zinc-200/80 dark:border-zinc-800/80',
          ]}
        >
          {tier.highlight && (
            <div class="mb-4 inline-flex w-fit items-center rounded-full bg-accent-600 px-2.5 py-0.5 text-xs font-medium text-white">
              Most popular
            </div>
          )}
          <h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-50">{tier.name}</h3>
          <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">{tier.audience}</p>
          <div class="mt-5 flex items-baseline gap-1">
            <span class="text-3xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50">
              {tier.price}
            </span>
            <span class="text-sm text-zinc-500 dark:text-zinc-400">{tier.priceNote}</span>
          </div>
          <ul class="mt-6 flex-1 space-y-2.5 text-sm">
            {tier.features.map((f) => (
              <li class="flex items-start gap-2 text-zinc-700 dark:text-zinc-300">
                <svg
                  class="mt-0.5 h-4 w-4 flex-shrink-0 text-accent-600 dark:text-accent-400"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>
          <a
            href={tier.cta.href}
            class:list={[
              'mt-7 inline-flex items-center justify-center rounded-md px-4 py-2.5 text-sm font-medium shadow-sm transition',
              tier.highlight
                ? 'bg-accent-600 text-white hover:bg-accent-700'
                : 'border border-zinc-300 bg-white text-zinc-900 hover:bg-zinc-50 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-100 dark:hover:bg-zinc-800',
            ]}
          >
            {tier.cta.label}
          </a>
        </div>
      ))}
    </div>

    <div class="mt-16 rounded-2xl border border-zinc-200/80 bg-zinc-50/70 p-8 text-center dark:border-zinc-800/80 dark:bg-zinc-950/40">
      <h3 class="text-xl font-semibold text-zinc-900 dark:text-zinc-50">
        Why we publish list prices.
      </h3>
      <p class="mx-auto mt-3 max-w-2xl text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
        Every commercial competitor in this category hides pricing behind contact-sales,
        or charges per investigation in a way that makes budgeting impossible. We don't.
        OSS is free. Team and Enterprise are flat per-cluster. Only the Federal track is
        contact-sales — because air-gap installers and SBOM work is genuinely bespoke.
      </p>
    </div>
  </section>
</BaseLayout>
