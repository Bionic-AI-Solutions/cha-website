---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Srenix &mdash; Agentic SRE',
  description = 'Detect, fix, and re-verify drift across Kubernetes, AWS, GCP, Azure, and the edge. Srenix is the autonomous Agentic SRE for K8s and the clouds underneath it.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://srenix.ai').toString();
const ogImage = new URL('/og-default.png', Astro.site ?? 'https://srenix.ai').toString();

// Page titles arrive with HTML entities (e.g. "Srenix &mdash; Pricing") for the
// <title> tag. Meta `content` attributes are plain text, so decode the few
// entities we actually use — `set:html` on a void <meta> element sets
// innerHTML (a no-op) and ships an EMPTY attribute. Never use set:html here.
const decodeEntities = (s: string) =>
  s
    .replace(/&mdash;/g, '—')
    .replace(/&ndash;/g, '–')
    .replace(/&rarr;/g, '→')
    .replace(/&amp;/g, '&');
const plainTitle = decodeEntities(title);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title set:html={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={plainTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={plainTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <!-- Fonts are self-hosted (see public/fonts/ + @font-face in src/styles/global.css). No third-party requests. -->
    <link
      rel="preload"
      href="/fonts/inter-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
